  <text n="Edictus Rothari">

    <body>

      <div n="Capitula 1-13" subtype="edition_text" type="capitula" xml:id="ER_1-13">

        <head> EXPLICIT PROLOGUS INCIPIUNT CAPITULA CAUSAS </head>

        <p n="1"><w>1</w>. <w>Si</w>
          <w>quis</w>
          <app>
            <lem><w>hominum</w></lem>
            <rdg wit="#B5"><w>homo</w></rdg>
            <rdg wit="#B3"/>
          </app>
          <w>contra</w>
          <w>animam</w>
          <w>regis</w>
          <app>
            <lem><w>cogitaverit</w></lem>
            <rdg wit="#B5"><w>considerauerit</w></rdg>
          </app>
          <app>
            <lem><w>aut</w>
              <app>
                <lem><w>consiliaverit</w></lem>
                <rdg wit="#B9"><w>consiliaberit</w></rdg>
                <rdg wit="#B11 #B12"><w>consiliatus</w>
                  <w>fuerit</w></rdg>
              </app></lem>
            <rdg wit="#B2 #B5"/>
          </app>, <w>animae</w>
          <w>suae</w>
          <w>incurrat</w>
          <w>periculum</w>
          <app>
            <lem><w>et</w></lem>
            <rdg wit="#B6"><w>aut</w></rdg>
          </app>
          <w>res</w>
          <w>eius</w>
          <w>infiscentur</w>.</p>

        <p n="2"><w>2</w>. <w>Si</w>
          <w>quis</w>
          <w>cum</w>
          <w>rege</w>
          <w>de</w>
          <w>morte</w>
          <w>alterius</w>
          <app>
            <lem><w>consiliaverit</w></lem>
            <rdg wit="#B11"><w>fuerit</w>
              <w>consiliatus</w></rdg>
          </app>, <w>aut</w>
          <w>hominem</w>
          <w>per</w>
          <w>ipsius</w>
          <w>iussionem</w>

          <!-- SAMPLE APP FOR INTEGRATED EDITION - CORRESP -->
          <!-- Il valore di xml:id che corrisponde a una singola parola -->
          
          <app>
            <lem><w>occiderit</w></lem>
            <rdg corresp="cv188:CV188_w_002-015" wit="#B2"><w>occiserit</w></rdg>
          </app>,

          <w>in</w>
          <w>nullo</w>
          <w>sit</w>
          <app>
            <lem resp="#azzara"><w>culpabilis</w></lem>
            <rdg resp="#bluhme" wit="#B2"><w>culpavelis</w></rdg>
            <rdg wit="#B5"><w>culbabilis</w></rdg>
          </app>, <w>nec</w>
          <w>ille</w>
          <w>nec</w>
          <app>
            <lem><w>heredes</w></lem>
            <rdg wit="#B2"><w>heredis</w></rdg>
            <rdg resp="hand1" wit="#B9"><w>heres</w></rdg>
          </app>
          <app>
            <lem><w>eius</w></lem>
            <rdg wit="#B10"><w>ipsius</w></rdg>
          </app>
          <app>
            <lem><w>quoquo</w></lem>
            <rdg wit="#B5"><w>quodque</w></rdg>
            <rdg wit="#B10"><w>quoque</w></rdg>
            <rdg wit="#B6 #B9"><w>quocunque</w></rdg>
          </app>
          <w>tempore</w>
          <app>
            <lem>
              <app>
                <lem><w>ab</w>
                  <w>illo</w></lem>
                <rdg wit="#B11"><w>aut</w>
                  <w>ille</w></rdg>
                <rdg wit="#B12"><w>ab</w>
                  <w>ullo</w></rdg>
              </app>
              <w>aut</w>
              <app>
                <lem wit="#B3 #B11 #B12"><w>heredes</w></lem>
                <rdg wit="#B1"><w>heroo</w></rdg>
                <rdg wit="#B2"><w>heredis</w></rdg>
                <rdg wit="#B9"><w>ab</w>
                  <w>herede</w></rdg>
                <rdg wit="#B6 #B8 #B9 #B12"><w>ab</w>
                  <w>heredibus</w></rdg>
              </app>
              <app>
                <lem><w>ipsius</w></lem>
                <rdg wit="#B2 #B11"/>
              </app>
            </lem>
            <rdg wit="#B5"/>
          </app>
          <app>
            <lem>
              <app>
                <lem><w>requisitionem</w></lem>
                <rdg wit="#B3"><w>requisitionis</w></rdg>
                <rdg wit="#B10 #B12"><w>requisitione</w></rdg>
              </app>
              <w>aut</w>
              <app>
                <lem wit="#B1 #B3 #B5"><w>molestia</w></lem>
                <rdg wit="#B2"><w>molestias</w></rdg>
                <rdg wit="#B6 #B8 #B11"><w>molestiam</w></rdg>
                <rdg wit="#B9"><w>molestationem</w></rdg>
              </app>
              <app>
                <lem><w>patiatur</w></lem>
                <rdg wit="#B11"><w>patiantur</w></rdg>
                <rdg wit="#B12"><w>afficiatur</w></rdg>
              </app>
            </lem>
            <rdg wit="#B5"><w>molestia</w>
              <w>paciatur</w>
              <w>aut</w>
              <w>requisicione</w></rdg>
          </app>; <w>quia</w>
          <app>
            <lem><w>postquam</w></lem>
            <rdg wit="#B5"/>
          </app>
          <app>
            <lem><w>corda</w></lem>
            <rdg wit="#B9"/>
          </app>
          <app>
            <lem><w>regum</w></lem>
            <rdg wit="#B5">regu</rdg>
          </app>
          <w>in</w>
          <app>
            <lem wit="#B1 #B2"><w>manum</w></lem>
            <rdg wit="#B3 #B4 #B5 #B6 #B7 #B8 #B9 #B10 #B11 #B12">manu</rdg>
          </app>
          <w>dei</w>

          <!-- SAMPLE APP FOR INTEGRATED EDITION - CORRESP 1 -->
          <!-- Il primo e l'ultimo valore di xml:id per ogni testimone -->
          <app>
            <lem><w>credimus</w>
              <w>esse</w></lem>
            <rdg corresp="cv188:CV188_w_002-025 cv188:CV188_w_002-026 ce34-5:CE34-5_w_002-025 ce34-5:CE34-5_w_002-026" wit="#B2 #B3">
              <w>esse</w>
              <w>credimus</w>
            </rdg>
          </app>, <w>non</w>
          <w>est</w>

          <!-- SAMPLE APP FOR INTEGRATED EDITION - CORRESP 2 -->
          <!-- Uso di range con @corresp per individuare le parole che compongono la lezione -->
          <app>
            <lem><w>credimus</w>
              <w>esse</w></lem>
            <rdg corresp="cv188:range(CV188_w_002-025,CV188_w_002-026) ce34-5:range(CE34-5_w_002-025,CE34-5_w_002-026)"
              wit="#B2 #B3">
              <w>esse</w>
              <w>credimus</w>
            </rdg>
          </app>, <w>non</w>
          <w>est</w>

          <!-- SAMPLE APP FOR INTEGRATED EDITION - SOURCE 1 -->
          <!-- Uso di range() per un singolo testimone; qui produce una duplicazione del <rdg> -->

          <app>
            <lem><w>credimus</w>
              <w>esse</w></lem>
            <rdg source="cv188:range(CV188_w_002-025,CV188_w_002-026)" wit="#B2">
              <w>esse</w>
              <w>credimus</w>
            </rdg>
            <rdg source="ce34-5:range(CE34-5_w_002-025,CE34-5_w_002-026)" wit="#B3">
              <w>esse</w>
              <w>credimus</w>
            </rdg>
          </app>, <w>non</w>
          <w>est</w>

          <!-- SAMPLE APP FOR INTEGRATED EDITION - SOURCE 2 -->
          <!-- Uso di range() per più testimoni nello stesso <rdg> -->

          <app>
            <lem><w>credimus</w>
              <w>esse</w></lem>
            <rdg source="cv188:range(CV188_w_002-025,CV188_w_002-026) ce34-5:range(CE34-5_w_002-025,CE34-5_w_002-026)"
              wit="#B2 #B3">
              <w>esse</w>
              <w>credimus</w>
            </rdg>
          </app>, <w>non</w>
          <w>est</w>

          <app>
            <lem><w>possibile</w></lem>
            <rdg wit="#B1"><w>possi|oo</w></rdg>
            <rdg wit="#B2"><w>possevilem</w></rdg>
          </app>, <w>ut</w>
          <w>homo</w>
          <w>possit</w><app>
            <lem/>
            <rdg wit="#B9">se</rdg>
          </app>
          <app>
            <lem wit="#B1 #B12"><w>eduniare</w></lem>
            <rdg wit="#B2"><w>aduniare</w></rdg>
            <rdg wit="#B3 #B5 #B8 #B9"><w>aedoniare</w></rdg>
            <rdg wit="#B6 #B11"><w>edoniare</w></rdg>
            <rdg wit="#B10 #B12"><w>idoniare</w></rdg>
          </app>, <w>quem</w>
          <w>rex</w>
          <app>
            <lem><w>occidere</w></lem>
            <rdg wit="#B8"><w>occidi</w></rdg>
            <rdg wit="#B5"><w>occiderit</w></rdg>
          </app>
          <app>
            <lem><w>iusserit</w></lem>
            <rdg wit="#B3 #B9 #B12"><w>iussit</w></rdg>
          </app>.</p>

        <p n="3"><w>3</w>. <w>Si</w>
          <w>quis</w>
          <app>
            <lem><w>foris</w></lem>
            <rdg wit="#B6 #B9 #B10"><w>foras</w></rdg>
          </app>
          <app>
            <lem><w>provincia</w></lem>
            <rdg wit="#B3 #B8 #B10 #B11"><w>prouinciam</w></rdg>
          </app>
          <app>
            <lem><w>fugire</w></lem>
            <rdg wit="#B5 #B6 #B10 #B11"><w>fugere</w></rdg>
          </app>
          <app>
            <lem><w>temptaverit</w></lem>
            <rdg wit="#B1">timtauerit</rdg>
          </app>
          <app>
            <rdg wit="#B5"><w>et</w>
              <w>inimicos</w>
              <w>inuitauerit</w>
              <w>aut</w>
              <w>introduxerit</w></rdg>
            <!-- add -->
            <note>Aggiunto dal capitulum successivo.</note>
          </app>, <app>
            <lem><w>morti</w></lem>
            <rdg wit="#B6 #B8 #B9 #B11 #B12"><w>mortis</w></rdg>
            <rdg wit="#B5"><w>animae</w>
              <w>suae</w></rdg>
          </app>
          <w>incurrat</w>
          <w>periculum</w>, <w>et</w>
          <w>res</w>
          <w>eius</w>
          <app>
            <lem><w>infiscentur</w></lem>
            <rdg wit="#B2"><w>infiscintur</w></rdg>
          </app>.</p>

        <p n="4"><w>4</w>. <w>Si</w>
          <w>quis</w>
          <app>
            <lem wit="#B1 #B2"><w>inimicûs</w></lem>
            <rdg wit="#B3 #B4 #B5 #B6 #B7 #B8 #B9 #B10 #B11 #B12"><w>inimicos</w></rdg>
            <rdg wit="#B12"><add place="margin"><w>inimicum</w>
                <w>suum</w></add></rdg>
            <note>Ceterum illa accusativi pluralis forma, veteribus libris usitatissima, a nobis littera û
              notabitur</note>
          </app>
          <app>
            <rdg wit="#B9"><w>regis</w></rdg>
          </app>
          <w>intra</w>
          <app>
            <lem wit="#B1 #B2 #B3"><w>provincia</w></lem>
            <rdg wit="#B4 #B5 #B6 #B7 #B8 #B9 #B10 #B11 #B12"><w>provinciam</w></rdg>
          </app>
          <app>
            <lem><w>invitaverit</w></lem>
            <rdg wit="#B5"><w>inuitare</w>
              <w>temptauerit</w></rdg>
          </app>
          <app>
            <lem><w>aut</w>
              <w>introduxerit</w>, <app>
                <lem><w>animae</w></lem>
                <rdg wit="#B5"><w>mortis</w></rdg>
              </app>
              <app>
                <rdg wit="#B5"/>
              </app></lem>
            <rdg wit="#B5"/>
          </app>
          <w>incurrat</w>
          <w>periculum</w>
          <w>et</w>
          <w>res</w>
          <w>eius</w>
          <app>
            <lem><w>infiscentur</w></lem>
            <rdg wit="#B3"><w>infescentur</w></rdg>
          </app>.</p>

        <p n="5"><w>5</w>. <w>Si</w>
          <w>quis</w>
          <app>
            <lem><w>scamaras</w></lem>
            <rdg wit="#B1"><w>escamaras</w></rdg>
            <rdg wit="#B5"><w>scameras</w></rdg>
            <rdg wit="#B11"><subst>
                <del><w>scamaris</w></del>
                <add><w>scamaros</w></add>
              </subst>
              <w>celatis</w></rdg>
            <rdg wit="#B12"><w>scaram</w></rdg>
            <rdg wit="#B12"><add place="margin"><w>scamuram</w></add></rdg>
          </app>
          <w>intra</w>
          <app>
            <lem wit="#B1 #B2 #B3"><w>provincia</w></lem>
            <rdg wit="#B4 #B5 #B6 #B7 #B8 #B9 #B10 #B11 #B12"><w>provinciam</w></rdg>
          </app>
          <app>
            <lem wit="#B1"><w>caelaverit</w></lem>
            <rdg wit="#B2 #B3 #B4 #B5 #B6 #B7 #B8 #B9 #B10 #B11 #B12"><w>celauerit</w></rdg>
          </app>
          <app>
            <lem><w>aut</w></lem>
            <rdg wit="#B11"><subst>
                <del>aut</del>
                <add><w>eis</w></add>
              </subst></rdg>
          </app>
          <app>
            <rdg wit="#B5"><w>eis</w></rdg>
          </app>
          <app>
            <lem><w>anonam</w></lem>
            <rdg wit="#B1"><unclear><w>anonam</w></unclear></rdg>
            <rdg wit="#B5 #B8 #B9 #B11 #B12"><w>annonam</w></rdg>
          </app>
          <w>dederit</w>, <w>animae</w>
          <w>suae</w>
          <w>incurrat</w>
          <w>periculum</w>, <w>aut</w>
          <app>
            <lem><w>certe</w></lem>
            <rdg wit="#B2 #B6 #B9 #B10"/>
            <rdg wit="#B12"><add place="margin"><w>certe</w></add></rdg>
          </app>
          <w>conponat</w>
          <w>regi</w>
          <w>solidûs</w>
          <w>noningentos</w>. </p>

        <p n="6">
          <w>6</w>. <w>Si</w>
          <w>quis</w>
          <w>foris</w>
          <w>in</w>
          <w>exercitum</w>
          <w>seditionem</w>
          <w>levaverit</w>
          <w>contra</w>
          <w>ducem</w>
          <w>suum</w>
          <w>aut</w>
          <w>contra</w>
          <w>eum</w>, <w>qui</w>
          <w>ordinatus</w>
